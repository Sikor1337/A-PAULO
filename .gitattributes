# Normalize line endings: store text files with LF in the repo,
# Git checks out native endings on each OS automatically.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Shell scripts must stay LF even on Windows
*.sh         text eol=lf

# Binary files — never touch
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.webp       binary
*.svg        text
*.pdf        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
